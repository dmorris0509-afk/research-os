# Preferred deployed authentication: GitHub App installation
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_PATH=

# Fine-grained, repository-scoped local-development fallback
GITHUB_TOKEN=

GITHUB_API_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28

# Research OS backend
RESEARCH_OS_ENVIRONMENT=development
RESEARCH_OS_DATABASE_URL=sqlite:///./research_os.db
RESEARCH_OS_WORKSPACE_ROOT=workspace
RESEARCH_OS_CORS_ORIGINS=["http://localhost:8501"]
RESEARCH_OS_AUTH_REQUIRED=false
# Required only when auth is enabled; use at least 32 random characters.
RESEARCH_OS_JWT_SECRET=
# OpenAI SDK credential (never commit the real value)
OPENAI_API_KEY=
